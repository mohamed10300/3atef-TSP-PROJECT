# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o

# Database (PostgreSQL for production, SQLite for dev)
DATABASE_URL=postgresql://user:password@localhost:5432/3atef_db
DATABASE_URL_SQLITE=sqlite:///./3atef_dev.db

# Email — Microsoft Outlook / Graph API
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# Email — Gmail API
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# App
ENVIRONMENT=development
API_PORT=8000
FRONTEND_URL=http://localhost:3000
# Comma-separated extra allowed origins (e.g. your Vercel URL)
ALLOWED_ORIGINS=
SECRET_KEY=

# Scraping
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT=30000
